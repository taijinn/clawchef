{
  "name": "clawchef",
  "private": true,
  "version": "1.0.2",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.0-beta.13",
    "vite-plugin-electron": "^0.29.0"
  },
  "overrides": {
    "vite": "^8.0.0-beta.13"
  },
  "build": {
    "appId": "com.clawchef.app",
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/icon.icns"
    },
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  }
